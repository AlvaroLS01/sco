<AnchorPane id="AnchorPane" prefWidth="700.0"
	prefHeight="421.0" minWidth="392.0"
	styleClass="mainFxmlClass, pantalla-detalle"
	xmlns="http://javafx.com/javafx/2.2"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.comerzzia.brico.pos.selfcheckout.gui.ventas.fidelizado.insertadatos.InsertarDatosFidelizadoController">

	<children>
		<HBox id="HBox" alignment="CENTER" spacing="5.0"
			AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
			AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
			<children>
				<VBox prefWidth="700.0" prefHeight="350.0" spacing="10.0"
					HBox.hgrow="ALWAYS">
					<children>

						<HBox prefWidth="700.0" prefHeight="50.0"
							styleClass="titulo-ventana" VBox.vgrow="NEVER">
							<children>
								<Label fx:id="lbTitulo"
									text="%Introduce tu DNI/NIF o email" styleClass="intro-number"
									alignment="CENTER" prefWidth="700.0" prefHeight="50.0" />
							</children>
						</HBox>

						<HBox alignment="CENTER" prefWidth="700.0" prefHeight="50.0"
							VBox.vgrow="ALWAYS">
							<children>
								<TextField fx:id="tfInsertarEmail"
									styleClass="text-corp, art-number" prefHeight="40.0"
									HBox.hgrow="ALWAYS">
									<HBox.margin>
										<Insets left="15.0" right="15.0" />
									</HBox.margin>
								</TextField>
							</children>
						</HBox>

						<HBox fx:id="panelTecladoNumerico" prefWidth="700.0"
							prefHeight="150.0" VBox.vgrow="ALWAYS" alignment="CENTER" />

						<HBox fx:id="panelCorreo" prefWidth="700.0" prefHeight="62.0"
							spacing="5.0" VBox.vgrow="ALWAYS" alignment="CENTER">
							<children>
								<Button fx:id="btnGmailEs" mnemonicParsing="false"
									styleClass="boton-fondo-black" text="\@gmail.es"
									textFill="WHITE" />

								<Button fx:id="btnGmailCom" mnemonicParsing="false"
									styleClass="boton-fondo-black" text="\@gmail.com"
									textFill="WHITE" />

								<Button id="btnOutlookCom" fx:id="btnHotmail"
									mnemonicParsing="false" styleClass="boton-fondo-black"
									text="\@hotmail.com" textFill="WHITE" />

								<!-- Nuevo botón @hotmail.es -->
								<Button fx:id="btnHotmailEs" mnemonicParsing="false"
									styleClass="boton-fondo-black" text="\@hotmail.es"
									textFill="WHITE" />

								<!-- Nuevo botón @yahoo.es -->
								<Button fx:id="btnYahooEs" mnemonicParsing="false"
									styleClass="boton-fondo-black" text="\@yahoo.es"
									textFill="WHITE" />

								<Button fx:id="btnOutlookEs" mnemonicParsing="false"
									styleClass="boton-fondo-black" text="\@outlook.es"
									textFill="WHITE" />

								<Button fx:id="btnOutlookCom" mnemonicParsing="false"
									styleClass="boton-fondo-black" text="\@outlook.com"
									textFill="WHITE" />

								<Button fx:id="btnSapo" mnemonicParsing="false"
									styleClass="boton-fondo-black" text="\@sapo.pt"
									textFill="WHITE" />

								<Button fx:id="btnAt" mnemonicParsing="false"
									styleClass="boton-fondo-black" text="\@" textFill="WHITE" />
							</children>
						</HBox>

						<HBox alignment="CENTER" prefWidth="200.0" prefHeight="50.0"
							VBox.vgrow="NEVER">
							<children>
								<Button fx:id="btAceptar" onAction="#accionAceptar"
									mnemonicParsing="false" styleClass="btAceptar, text-black"
									text="%Aceptar" minWidth="115.0" minHeight="42.0"
									prefHeight="42.0">
									<font>
										<Font size="16.0" fx:id="x1" />
									</font>
								</Button>

								<Button fx:id="btCancelar" onAction="#accionCancelar"
									mnemonicParsing="false" styleClass="btCancelar, text-black"
									text="%Cancelar">
									<HBox.margin>
										<Insets left="10.0" />
									</HBox.margin>
								</Button>
							</children>
							<padding>
								<Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
							</padding>
						</HBox>

					</children>
				</VBox>
			</children>
		</HBox>
	</children>

	<stylesheets>
		<URL value="@../../styles/styles.css" />
		<URL value="@insertardatosfidelizado.css" />
	</stylesheets>
</AnchorPane>